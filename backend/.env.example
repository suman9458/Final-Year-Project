PORT=4000
# Comma-separated origins allowed to call backend APIs
# Example: http://localhost:5173,https://yourdomain.com
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mini_trade
# Or use one connection string:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/mini_trade
# DB_SSL=false

# OTP SMS Provider (Twilio)
# NODE_ENV=development
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Use one of the following:
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# For testing deployments only:
# If true, production can return demo OTP when Twilio is not configured.
ALLOW_DEMO_OTP_IN_PRODUCTION=false
